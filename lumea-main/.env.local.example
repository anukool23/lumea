# ── BFF: backend URLs (server-side only) ─────────────────────────────────────
AUTH_API_URL=https://<lumea-auth-lambda-url>.lambda-url.ap-south-1.on.aws
POST_API_URL=https://<lumea-post-lambda-url>.lambda-url.ap-south-1.on.aws
CONTENT_API_URL=https://<lumea-content-lambda-url>.lambda-url.ap-south-1.on.aws
INTERACTION_API_URL=https://<lumea-interaction-lambda-url>.lambda-url.ap-south-1.on.aws
ANALYTICS_API_URL=https://<lumea-analytics-lambda-url>.lambda-url.ap-south-1.on.aws
NOTIFICATIONS_API_URL=https://<lumea-notifications-lambda-url>.lambda-url.ap-south-1.on.aws
AI_API_URL=https://<lumea-ai-lambda-url>.lambda-url.ap-south-1.on.aws
MEDIA_API_URL=https://<lumea-media-worker>.workers.dev

# ── BFF: API key injected into every proxied request ─────────────────────────
API_KEY=

# ── Public env vars ───────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_WRITE_URL=http://localhost:3001
