# Lumea Admin environment variables
# Copy to .env.local and fill in values

# Admin credentials (simple password auth)
ADMIN_EMAIL=admin@lumea.ink
ADMIN_PASSWORD=change_me_in_production

# Internal API key (must match all Lambda services)
INTERNAL_API_KEY=your_internal_api_key_here

# Lambda function URLs (no trailing slash)
POST_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws
AUTH_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws
COMMS_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws
ANALYTICS_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws
NOTIFICATIONS_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws
INTERACTION_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws
AI_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws

# Upstash Redis (for cache flush)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token_here
