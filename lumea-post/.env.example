# ── Server ────────────────────────────────────────────────────────────────────
PORT=8787
NODE_ENV=development           # production on Lambda

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/lumea?retryWrites=true&w=majority
MONGODB_URI=
# ── Auth (same values as lumea-auth) ─────────────────────────────────────────
JWT_SECRET=

# ── Upstash Redis (same instance as lumea-auth for JWT blacklist) ─────────────
# UPSTASH_REDIS_URL=rediss://default:TOKEN@HOST.upstash.io:6379
# UPSTASH_REDIS_TOKEN=YOUR-UPSTASH-REST-TOKEN

UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=


# ── BFF API keys (same 4 keys as lumea-auth, hyphen-separated) ──────────────
# API_KEYS=key1-key2-key3-key4
API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=

# ── Swagger UI server URL (set to Lambda Function URL on production) ──────────
# Leave unset locally — defaults to http://localhost:PORT
SWAGGER_SERVER_URL=https://YOUR-LAMBDA-URL.lambda-url.ap-south-1.on.aws
