# Lumea-Info environment variables
# Copy to .env.local and fill in values

# Public URLs (used in metadata + links)
NEXT_PUBLIC_APP_URL=https://info.lumea.ink
NEXT_PUBLIC_MAIN_URL=https://lumea.ink
NEXT_PUBLIC_WRITE_URL=https://write.lumea.ink

# Internal API — server-side only
INTERNAL_API_KEY=your_internal_api_key_here

# lumea-comms Lambda function URL (no trailing slash)
COMMS_API_URL=https://xxxxx.lambda-url.ap-south-1.on.aws

# Contact form
CONTACT_RECIPIENT_EMAIL=hello@lumea.ink
