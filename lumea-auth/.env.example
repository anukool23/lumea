# ── Server ──────────────────────────────────────────────────────────────────
PORT=8080
RUN_MODE=local           # local | lambda
DEBUG_OTP=true           # true → print OTP to console (LOCAL ONLY, never production)

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_DSN=
# ── Redis / Upstash ──────────────────────────────────────────────────────────
# Local: redis://localhost:6379
# Upstash (production): rediss://:TOKEN@HOST:6380
REDIS_URL=

# ── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=8cRBw1w
JWT_EXPIRY_HOURS=168     # 7 days

# ── Password Reset ───────────────────────────────────────────────────────────
RESET_TOKEN_EXPIRY_MINUTES=60

# ── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_MINUTES=10

# ── Communication Service (email/OTP sending) ────────────────────────────────
# Leave blank in local mode — OTPs will be logged to console
COMMS_SERVICE_URL=
INTERNAL_SERVICE_TOKEN=replace-with-shared-secret

# ── Firebase (Google OAuth) ───────────────────────────────────────────────────
# Base64-encoded Firebase Admin SDK service account JSON
FIREBASE_CREDENTIALS=

# ── CORS ─────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── BFF API Keys ─────────────────────────────────────────────────────────────
# Pipe-delimited valid keys — split on "-" at runtime. Leave blank in local dev
# to bypass the check. In production set all 4 keys here.
API_KEYS=