# ── Server ────────────────────────────────────────────────────────────────────
PORT=8788
NODE_ENV=development

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://lumea:<password>@cluster0.xxxxx.mongodb.net/lumea?retryWrites=true&w=majority

# ── OpenSearch ────────────────────────────────────────────────────────────────
OPENSEARCH_URL=https://your-domain.us-east-1.es.amazonaws.com
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=

# ── Redis / Upstash ───────────────────────────────────────────────────────────
UPSTASH_REDIS_URL=https://YOUR-ENDPOINT.upstash.io
UPSTASH_REDIS_TOKEN=YOUR-TOKEN

# ── JWT (same secret as lumea-auth) ──────────────────────────────────────────
JWT_SECRET=replace-this-with-a-very-long-random-secret-min-32-chars

# ── Auth Service (for following list) ─────────────────────────────────────────
AUTH_SERVICE_URL=http://localhost:8080
INTERNAL_SERVICE_TOKEN=replace-with-shared-secret
