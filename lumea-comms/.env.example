# ── Server ────────────────────────────────────────────────────────────────────
PORT=8791
NODE_ENV=development           # production on Lambda

# ── PostgreSQL (Neon / RDS / Supabase) ───────────────────────────────────────
# POSTGRES_DSN=postgresql://USER:PASS@HOST/DB?sslmode=require
POSTGRES_DSN=

# ── Internal service auth ─────────────────────────────────────────────────────
# Must match INTERNAL_SERVICE_TOKEN in lumea-auth and any other caller
INTERNAL_SERVICE_TOKEN=

# ── AWS SES ───────────────────────────────────────────────────────────────────
AWS_REGION=ap-south-1
SES_FROM_EMAIL=noreply@lumea.ink

# ── App URL (used in email link generation) ───────────────────────────────────
APP_URL=https://lumea.ink

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Swagger UI server URL (set to Lambda Function URL on production) ──────────
# Leave unset locally — defaults to http://localhost:PORT
SWAGGER_SERVER_URL=https://YOUR-LAMBDA-URL.lambda-url.ap-south-1.on.aws
