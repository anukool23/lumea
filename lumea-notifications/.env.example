# ── Server ────────────────────────────────────────────────────────────────────
PORT=8793
NODE_ENV=development           # production on Lambda

# ── MongoDB Atlas (same cluster as other services) ────────────────────────────
MONGODB_URI=

# ── Auth (same JWT_SECRET as lumea-auth) ─────────────────────────────────────
JWT_SECRET=

# ── Internal service auth ─────────────────────────────────────────────────────
INTERNAL_SERVICE_TOKEN=

# ── BFF API keys (hyphen-separated) ──────────────────────────────────────────
API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://lumea.ink,https://dash.lumea.ink

# ── Swagger UI server URL ─────────────────────────────────────────────────────
SWAGGER_SERVER_URL=https://YOUR-LAMBDA-URL.lambda-url.ap-south-1.on.aws
