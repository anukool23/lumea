# ── AI providers (cascade: Groq → OpenRouter → Cohere) ───────────────────────
GROQ_API_KEY=gsk_...
OPENROUTER_API_KEY=sk-or-...
COHERE_API_KEY=...

# ── Auth (same JWT_SECRET as lumea-auth) ─────────────────────────────────────
JWT_SECRET=

# ── Upstash Redis (HTTP REST — use the REST API URL + token, NOT rediss://) ──
# Get from Upstash console → your database → REST API tab
UPSTASH_REDIS_URL=https://YOUR-ENDPOINT.upstash.io
UPSTASH_REDIS_TOKEN=YOUR-UPSTASH-REST-TOKEN

# ── BFF API keys (hyphen-separated, same as other services) ──────────────────
API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://lumea.ink,https://dash.lumea.ink

# ── App ───────────────────────────────────────────────────────────────────────
APP_URL=https://lumea.ink
NODE_ENV=development           # production on Vercel
