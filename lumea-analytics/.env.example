# ── Server ────────────────────────────────────────────────────────────────────
PORT=8792
NODE_ENV=development           # production on Lambda

# ── OpenSearch (Amazon OpenSearch Service or self-hosted) ─────────────────────
# OPENSEARCH_URL=https://search-DOMAIN.ap-south-1.es.amazonaws.com
OPENSEARCH_URL=
OPENSEARCH_USERNAME=
OPENSEARCH_PASSWORD=

# ── MongoDB Atlas (same cluster as lumea-post / lumea-interaction) ────────────
MONGODB_URI=

# ── Auth (same JWT_SECRET as lumea-auth) ─────────────────────────────────────
JWT_SECRET=

# ── BFF API keys (same keys as other services, hyphen-separated) ─────────────
# API_KEYS=key1-key2-key3-key4
API_KEYS=

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://lumea.ink,https://dash.lumea.ink

# ── Swagger UI server URL ─────────────────────────────────────────────────────
# Leave unset locally — defaults to http://localhost:PORT
SWAGGER_SERVER_URL=https://YOUR-LAMBDA-URL.lambda-url.ap-south-1.on.aws
