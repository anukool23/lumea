{
  "name": "lumea-analytics",
  "version": "1.0.0",
  "description": "Lumea Analytics Service — event ingestion and writer stats via OpenSearch",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/local.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@aws-sdk --external:pino-pretty",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts"
  },
  "dependencies": {
    "@hono/swagger-ui": "^0.4.1",
    "@hono/zod-openapi": "^0.18.0",
    "@opensearch-project/opensearch": "^2.13.0",
    "hono": "^4.5.0",
    "mongodb": "^6.8.0",
    "pino": "^9.3.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@hono/node-server": "^1.12.0",
    "@types/node": "^22.0.0",
    "esbuild": "^0.23.0",
    "pino-pretty": "^11.2.1",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
